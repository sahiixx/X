# MongoDB Configuration (for production docker-compose.prod.yml)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme

# Backend Configuration
# MONGO_URL will be automatically set in docker-compose
# For local development, create backend/.env with:
# MONGO_URL=mongodb://localhost:27017/digital_agency

# Frontend Configuration
# For local development, create frontend/.env with:
# REACT_APP_BACKEND_URL=http://localhost:8000
